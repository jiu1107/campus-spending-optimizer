.container {
  display: flex;
  width: 100%;
  height: calc(100vh - 56px);
  overflow: hidden;
}
.sidebar {
  width: 340px;
  min-width: 340px;
  height: 100%;
  background: #ffffff;
  border-right: 0.5px solid var(--color-border);
  display: flex;
  flex-direction: column;
  overflow-y: auto;
  flex-shrink: 0;
}
.map {
  width: 100%;
  height: 100%;
}
.section {
  padding: 16px 18px;
  border-bottom: 0.5px solid var(--color-border);
  display: flex;
  flex-direction: column;
}
.sectionHeader {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10px;
}
.sectionTitle {
  font-size: 12px;
  font-weight: 500;
  color: var(--color-text-primary);
  margin-bottom: 10px;
  display: block;
}
.resetBtn {
  font-size: 11px;
  color: var(--color-text-secondary);
  background: none;
  border: none;
  cursor: pointer;
  padding: 0;
}
.resetBtn:hover { color: var(--color-primary); }
.categoryRow {
  display: flex;
  flex-wrap: nowrap;
  gap: 6px;
  overflow-x: auto;
}
.catBtn {
  display: flex;
  align-items: center;
  gap: 4px;
  height: 30px;
  padding: 0 8px;
  border-radius: 20px;
  font-size: 11px;
  font-weight: 500;
  border: 0.5px solid var(--color-border);
  background: #F9FAFB;
  color: var(--color-text-secondary);
  cursor: pointer;
  transition: all 0.15s;
  white-space: nowrap;
  flex-shrink: 0;
}
.catBtn:hover { border-color: var(--color-primary); color: var(--color-primary); }
.catBtn.active { color: white; }

/* 카드 체크 */
.cardList {
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.cardCheck {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 12px;
  border-radius: 10px;
  border: 0.5px solid var(--color-border);
  background: #F9FAFB;
  cursor: pointer;
  transition: all 0.15s;
}
.cardCheck:hover { border-color: var(--color-primary); }
.cardChecked {
  border-color: var(--color-primary) !important;
  background: var(--color-primary-light) !important;
}
.cardCheck input {
  accent-color: var(--color-primary);
  width: 14px;
  height: 14px;
  flex-shrink: 0;
}
.cardCheckInfo {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex: 1;
}
.cardCheckName {
  font-size: 12px;
  font-weight: 500;
  color: var(--color-text-primary);
}
.cardCheckRate {
  font-size: 11px;
  font-weight: 500;
}

/* 상태 박스 */
.stateBox {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24px 16px;
  gap: 8px;
  flex: 1;
}
.stateText {
  font-size: 12px;
  color: var(--color-text-secondary);
  text-align: center;
  line-height: 1.6;
}

/* 가게 정보 */
.storeInfo {
  display: flex;
  flex-direction: column;
  gap: 13px;
}
.storeNameRow {
  display: flex;
  align-items: flex-start;
  gap: 10px;
}
.storeIconBox {
  width: 36px;
  height: 36px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.storeName {
  font-size: 13px;
  font-weight: 500;
  color: var(--color-text-primary);
  margin: 0 0 2px;
  line-height: 1.4;
}
.storeAddress {
  font-size: 11px;
  color: var(--color-text-secondary);
  margin: 0;
  line-height: 1.4;
}
.storeMetaRow {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.storeTag {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  background: #F9FAFB;
  border: 0.5px solid var(--color-border);
  border-radius: 20px;
  padding: 3px 10px;
  font-size: 11px;
  color: var(--color-text-secondary);
}
.storeDistance {
  font-size: 11px;
  color: var(--color-text-secondary);
}

/* 혜택 목록 */
.benefitList {
  display: flex;
  flex-direction: column;
  gap: 5px;
}
.benefitItem {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 9px 12px;
  background: #F9FAFB;
  border-radius: 8px;
  border: 0.5px solid var(--color-border);
}
.benefitItem.best {
  background: var(--color-primary-light);
  border-color: var(--color-primary);
}
.benefitLeft {
  display: flex;
  align-items: center;
  gap: 6px;
}
.benefitBadge {
  font-size: 10px;
  padding: 2px 7px;
  border-radius: 20px;
  font-weight: 500;
}
.bestBadge {
  background: var(--color-primary);
  color: white;
}
.normalBadge {
  background: #F1F5F9;
  color: var(--color-text-secondary);
  border: 0.5px solid var(--color-border);
}
.benefitCardName {
  font-size: 12px;
  font-weight: 500;
  color: var(--color-text-primary);
}
.benefitRate {
  font-size: 12px;
  font-weight: 500;
}
.nobenefitBox {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 8px 10px;
  background: #F9FAFB;
  border-radius: 8px;
  font-size: 11px;
  color: var(--color-text-secondary);
}

/* 팁 */
.tipSection {
  padding: 14px 18px;
  margin-top: auto;
}
.tipBox {
  display: flex;
  align-items: flex-start;
  gap: 7px;
  background: var(--color-primary-light);
  border-radius: 10px;
  padding: 10px 12px;
  font-size: 11px;
  color: var(--color-primary);
  line-height: 1.6;
}

/* 범례 */
.legend {
  position: absolute;
  bottom: 20px;
  right: 20px;
  background: white;
  border-radius: 12px;
  border: 0.5px solid var(--color-border);
  padding: 12px 16px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  z-index: 10;
  pointer-events: none;
}
.legendTitle {
  font-size: 11px;
  font-weight: 500;
  color: var(--color-text-primary);
  margin: 0 0 2px;
}
.legendItem {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 11px;
  color: var(--color-text-secondary);
}
.legendDot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  flex-shrink: 0;
}

/* 범위 이탈 */
.outOfRange {
  position: absolute;
  top: 16px;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0,0,0,0.7);
  color: #fff;
  font-size: 12px;
  padding: 10px 16px;
  border-radius: 20px;
  white-space: nowrap;
  z-index: 10;
  pointer-events: none;
  display: flex;
  align-items: center;
  gap: 6px;
}